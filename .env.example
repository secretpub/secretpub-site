# ─────────────────────────────────────────────────────────────
# secretpub.fr — variables d'environnement
# Copie ce fichier en `.env.local` et remplis les valeurs.
# Le SITE FONCTIONNE SANS Supabase (contenu par défaut). Supabase
# n'est nécessaire QUE pour activer le CMS /admin et la capture de leads.
# ─────────────────────────────────────────────────────────────

# --- Supabase (projet DÉDIÉ au site public, séparé du dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role — SERVEUR UNIQUEMENT, ne jamais exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=

# --- CMS /admin ---
# Emails autorisés à se connecter au back-office (séparés par des virgules).
ADMIN_ALLOWED_EMAILS=contact@secretpub.fr

# --- Notifications de leads (optionnel) ---
# Adresse qui reçoit les demandes de contact / liste d'attente.
LEADS_NOTIFY_EMAIL=contact@secretpub.fr

# --- Revalidation à la publication depuis /admin ---
# Secret interne pour déclencher la régénération des pages après une sauvegarde.
REVALIDATE_SECRET=change-me-long-random-string

# --- Métadonnées ---
NEXT_PUBLIC_SITE_URL=https://secretpub.fr
